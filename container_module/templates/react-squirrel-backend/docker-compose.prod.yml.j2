# Production docker-compose for {{ app_name }}
# Deployed tag: {{ image_tag }}
# Generated by Ansible - do not edit manually
# Uses external database and redis (connection strings passed as environment variables)

x-common-env: &common-env
  SQUIRREL_DATABASE_URL: {{ database_url }}
{% if redis_url is defined and redis_url %}
  SQUIRREL_REDIS_URL: {{ redis_url }}
{% endif %}
  SQUIRREL_DEBUG: "false"

services:
  api:
    image: {{ ghcr_image }}:{{ image_tag }}
    container_name: {{ app_name }}-api
    command: uvicorn app.main:app --host 0.0.0.0 --port {{ api_port | default(8080) }} --workers {{ api_workers | default(4) }}
    ports:
      - "{{ api_port | default(8080) }}:{{ api_port | default(8080) }}"
    environment:
      <<: *common-env
    restart: unless-stopped

  monitor:
    image: {{ ghcr_image }}:{{ image_tag }}
    container_name: {{ app_name }}-monitor
    command: python -m app.monitor_main
    environment:
      <<: *common-env
    restart: unless-stopped
    deploy:
      replicas: 1

  worker:
    image: {{ ghcr_image }}:{{ image_tag }}
    command: arq app.worker.WorkerSettings
    environment:
      <<: *common-env
    restart: unless-stopped
    deploy:
      replicas: {{ worker_replicas | default(2) }}

networks:
  default:
    name: {{ docker_network }}
    external: true
